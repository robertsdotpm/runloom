{
  "_README": "The kernel-interface trust surface. Every syscall/libc call runloom depends on, with its DOCUMENTED return set (man pages, Linux). This is the ONLY thing a demonic-oracle proof (tools/verify/cbmc/*_demonic_cbmc.c) or a compile-time-exhaustive Result enum (Idea 1) has to assume about the kernel -- not that it behaves, only that its returns are a SUBSET of this list. Finite + auditable = the reduced trust surface. 'class': transient=(kernel says retry: the call must loop/repark, never propagate); hard=(propagate to the fiber as an error); fatal=(a bug in OUR args -- EINVAL/EBADF: should be unreachable, assert). 'ok' describes the success return.",
  "syscalls": {
    "epoll_wait": {"ok": ">=0 (nready)", "class": {"transient": ["EINTR"], "fatal": ["EBADF", "EFAULT", "EINVAL"]}, "note": "EINTR must retry; a hard failure here wedges the pump -> back off, never busy-spin"},
    "epoll_ctl": {"ok": "0", "class": {"hard": ["ENOMEM", "ENOSPC", "EPERM"], "fatal": ["EBADF", "EEXIST", "EINVAL", "ELOOP", "ENOENT"]}, "note": "ADD after DEL failing = fd registered nowhere -> the demonic-harness lost-wake window (netpoll_arm_demonic_cbmc.c)"},
    "epoll_create1": {"ok": ">=0 (fd)", "class": {"hard": ["EMFILE", "ENFILE", "ENOMEM"], "fatal": ["EINVAL"]}},
    "eventfd": {"ok": ">=0 (fd)", "class": {"hard": ["EMFILE", "ENFILE", "ENODEV", "ENOMEM"], "fatal": ["EINVAL"]}},
    "eventfd_write": {"ok": "0", "class": {"transient": ["EAGAIN"], "fatal": ["EBADF", "EINVAL"]}},
    "timerfd_create": {"ok": ">=0 (fd)", "class": {"hard": ["EMFILE", "ENFILE", "ENOMEM"], "fatal": ["EINVAL"]}},
    "timerfd_settime": {"ok": "0", "class": {"fatal": ["EBADF", "EFAULT", "EINVAL"]}},
    "recv": {"ok": ">=0 (n; 0=EOF)", "class": {"transient": ["EAGAIN", "EINTR"], "hard": ["ECONNRESET", "ETIMEDOUT", "ENOMEM", "ECONNREFUSED"], "fatal": ["EBADF", "ENOTCONN", "EINVAL"]}, "note": "short read (n<len) is a SUCCESS value, not an error -- a whole class of its own"},
    "recvfrom": {"ok": ">=0 (n)", "class": {"transient": ["EAGAIN", "EINTR"], "hard": ["ECONNRESET", "ENOMEM"], "fatal": ["EBADF", "EINVAL"]}},
    "recvmsg": {"ok": ">=0 (n)", "class": {"transient": ["EAGAIN", "EINTR"], "hard": ["ECONNRESET", "ENOMEM"], "fatal": ["EBADF", "EINVAL"]}},
    "send": {"ok": ">=0 (n; may be SHORT)", "class": {"transient": ["EAGAIN", "EINTR"], "hard": ["EPIPE", "ECONNRESET", "ENOBUFS", "ENOMEM"], "fatal": ["EBADF", "ENOTCONN", "EMSGSIZE"]}, "note": "short write (n<len) is SUCCESS -- caller must loop the remainder or it silently drops data"},
    "sendto": {"ok": ">=0 (n)", "class": {"transient": ["EAGAIN", "EINTR"], "hard": ["EPIPE", "ECONNRESET", "ENOBUFS"], "fatal": ["EBADF"]}},
    "sendmsg": {"ok": ">=0 (n)", "class": {"transient": ["EAGAIN", "EINTR"], "hard": ["EPIPE", "ECONNRESET", "ENOBUFS"], "fatal": ["EBADF"]}},
    "read": {"ok": ">=0 (n; 0=EOF; may be SHORT)", "class": {"transient": ["EAGAIN", "EINTR"], "hard": ["EIO", "ENOMEM"], "fatal": ["EBADF", "EINVAL", "EISDIR"]}},
    "write": {"ok": ">=0 (n; may be SHORT)", "class": {"transient": ["EAGAIN", "EINTR"], "hard": ["EIO", "EPIPE", "ENOSPC", "EDQUOT"], "fatal": ["EBADF", "EINVAL"]}},
    "accept": {"ok": ">=0 (fd)", "class": {"transient": ["EAGAIN", "EINTR", "ECONNABORTED"], "hard": ["EMFILE", "ENFILE", "ENOBUFS", "ENOMEM", "EPERM"], "fatal": ["EBADF", "EINVAL", "ENOTSOCK", "EOPNOTSUPP"]}, "note": "ECONNABORTED is transient (a peer aborted before accept) -- must retry, not propagate"},
    "accept4": {"ok": ">=0 (fd)", "class": {"transient": ["EAGAIN", "EINTR", "ECONNABORTED"], "hard": ["EMFILE", "ENFILE", "ENOMEM"], "fatal": ["EBADF", "EINVAL"]}},
    "connect": {"ok": "0 (or EINPROGRESS async)", "class": {"transient": ["EINTR", "EINPROGRESS", "EALREADY", "EAGAIN"], "hard": ["ECONNREFUSED", "ETIMEDOUT", "ENETUNREACH", "EHOSTUNREACH", "ECONNRESET", "EADDRNOTAVAIL"], "fatal": ["EBADF", "EAFNOSUPPORT", "EISCONN"]}, "note": "EINPROGRESS is the async-connect SUCCESS path (park on writable), NOT an error -- mis-classing it = hang"},
    "socket": {"ok": ">=0 (fd)", "class": {"hard": ["EMFILE", "ENFILE", "ENOBUFS", "ENOMEM"], "fatal": ["EAFNOSUPPORT", "EINVAL", "EPROTONOSUPPORT"]}},
    "bind": {"ok": "0", "class": {"hard": ["EADDRINUSE", "EACCES"], "fatal": ["EBADF", "EINVAL", "ENOTSOCK"]}},
    "listen": {"ok": "0", "class": {"hard": ["EADDRINUSE"], "fatal": ["EBADF", "ENOTSOCK", "EOPNOTSUPP"]}},
    "setsockopt": {"ok": "0", "class": {"fatal": ["EBADF", "EINVAL", "ENOPROTOOPT", "ENOTSOCK"]}},
    "getsockopt": {"ok": "0", "class": {"fatal": ["EBADF", "EINVAL", "ENOPROTOOPT", "ENOTSOCK"]}},
    "getsockname": {"ok": "0", "class": {"fatal": ["EBADF", "EFAULT", "EINVAL", "ENOTSOCK"]}},
    "close": {"ok": "0", "class": {"transient": ["EINTR"], "hard": ["EIO", "ENOSPC", "EDQUOT"]}, "note": "EINTR-on-close is a footgun: on Linux the fd IS closed regardless -> must NOT retry close (double-close a reused fd)"},
    "dup": {"ok": ">=0 (fd)", "class": {"hard": ["EMFILE"], "fatal": ["EBADF"]}},
    "dup2": {"ok": ">=0 (fd)", "class": {"transient": ["EINTR", "EBUSY"], "hard": ["EMFILE"], "fatal": ["EBADF"]}},
    "pipe": {"ok": "0", "class": {"hard": ["EMFILE", "ENFILE"], "fatal": ["EFAULT", "EINVAL"]}},
    "pipe2": {"ok": "0", "class": {"hard": ["EMFILE", "ENFILE"], "fatal": ["EINVAL"]}},
    "fcntl": {"ok": ">=0 (cmd-dependent)", "class": {"transient": ["EINTR", "EAGAIN"], "hard": ["EMFILE", "ENOLCK"], "fatal": ["EBADF", "EINVAL", "EPERM"]}},
    "poll": {"ok": ">=0 (nready)", "class": {"transient": ["EINTR"], "hard": ["ENOMEM"], "fatal": ["EFAULT", "EINVAL"]}},
    "select": {"ok": ">=0 (nready)", "class": {"transient": ["EINTR"], "hard": ["ENOMEM"], "fatal": ["EBADF", "EINVAL"]}},
    "malloc": {"ok": "!=NULL (ptr)", "class": {"hard": ["ENOMEM (returns NULL)"]}, "note": "failure = NULL return (errno ENOMEM); a missed NULL check = deref crash"},
    "calloc": {"ok": "!=NULL (ptr)", "class": {"hard": ["ENOMEM (returns NULL)"]}},
    "realloc": {"ok": "!=NULL (ptr)", "class": {"hard": ["ENOMEM (returns NULL; ORIGINAL still valid -- must not leak it)"]}, "note": "realloc-fail leaks the original if you overwrite the ptr with NULL -- a classic error-path leak"},
    "mmap": {"ok": "!=MAP_FAILED (ptr)", "class": {"hard": ["ENOMEM", "EAGAIN", "EMFILE"], "fatal": ["EINVAL", "EACCES"]}, "note": "failure = MAP_FAILED ((void*)-1), NOT NULL -- a NULL check misses it"},
    "posix_memalign": {"ok": "0", "class": {"hard": ["ENOMEM"], "fatal": ["EINVAL"]}, "note": "returns errno directly (does NOT set errno), 0=success -- easy to mis-check as an fd-style -1"},
    "io_uring_setup": {"ok": ">=0 (fd)", "class": {"hard": ["ENOMEM", "EMFILE", "ENFILE"], "fatal": ["EINVAL", "EPERM"], "degraded": ["EOPNOTSUPP", "ENOSYS"]}, "note": "ENOSYS/EOPNOTSUPP = no io_uring on this kernel -> MUST fall back to epoll, not fail"},
    "io_uring_enter": {"ok": ">=0 (nsubmitted)", "class": {"transient": ["EAGAIN", "EINTR", "EBUSY"], "hard": ["ENOMEM"], "fatal": ["EBADF", "EINVAL", "EOPNOTSUPP"]}},
    "io_uring_register": {"ok": ">=0", "class": {"hard": ["ENOMEM"], "fatal": ["EBADF", "EINVAL", "EOPNOTSUPP"]}},
    "pthread_create": {"ok": "0", "class": {"hard": ["EAGAIN", "ENOMEM"], "fatal": ["EINVAL", "EPERM"]}, "note": "returns errno directly (does NOT set errno); EAGAIN = out of threads -> the hub-spawn admission cap"},
    "pthread_mutex_init": {"ok": "0", "class": {"hard": ["ENOMEM", "EAGAIN"], "fatal": ["EINVAL", "EPERM"]}},
    "getrandom": {"ok": ">=0 (n)", "class": {"transient": ["EINTR", "EAGAIN"], "fatal": ["EINVAL", "EFAULT"]}},
    "sysconf": {"ok": ">=0 (value; -1 also VALID for unlimited)", "class": {"fatal": ["EINVAL"]}, "note": "-1 return is AMBIGUOUS: error IFF errno set -- must clear errno before the call"}
  }
}
