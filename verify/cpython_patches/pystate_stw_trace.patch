+/* ---- runloom STW trace-conformance instrumentation (env RUNLOOM_STW_TRACE) ----
+ * Emits the stop-the-world handshake transitions (machine M2) as one ndjson line
+ * each, keyed by the PyThreadState pointer, so tools/stw_trace_conform.py can
+ * replay the REAL CPython STW protocol through verify/tla/RunloomCPythonSTW.tla's
+ * OWN actions under TLC -- conforming runloom's interaction against the host's
+ * actual stop_the_world, not a transcription.  No-op (and near-zero) when the env
+ * is unset.  Self-contained: its own leaf mutex makes the lazy open + append safe
+ * regardless of which runtime lock is held at the call site, so the emits can sit
+ * exactly at the transition points.  This is the ONLY runloom edit to the CPython
+ * tree (snapshot kept at Python/pystate.c.runloom-orig). */
+static void
+runloom_stw_trace(const char *action, void *key)
+{
+    static PyMutex mtx;
+    static FILE *fp;
+    static int inited;
+    PyMutex_Lock(&mtx);
+    if (!inited) {
+        inited = 1;
+        const char *path = getenv("RUNLOOM_STW_TRACE");
+        if (path != NULL && path[0] != '\0') {
+            fp = fopen(path, "a");
+        }
+    }
+    if (fp != NULL) {
+        fprintf(fp, "{\"a\":\"%s\",\"t\":%llu}\n",
+                action, (unsigned long long)(uintptr_t)key);
+        fflush(fp);
+    }
+    PyMutex_Unlock(&mtx);
+}
