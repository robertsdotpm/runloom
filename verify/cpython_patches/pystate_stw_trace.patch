+/* ---- runloom STW trace-conformance instrumentation (env RUNLOOM_STW_TRACE) ----
+ * Emits the stop-the-world handshake (M1 attach/detach + M2 stop_the_world) as one
+ * ndjson line per transition so tools/stw_trace_conform.py can replay the REAL
+ * CPython STW protocol through verify/tla/RunloomCPythonSTW.tla's OWN actions under
+ * TLC.  Each line carries the tstate's UNIQUE id (tstate->id -- disambiguates a
+ * REUSED PyThreadState pointer) and a seq-cst logical-clock stamp s (runloom_stw_tick,
+ * placed before a publishing store / after a dependent read) so the conform tool can
+ * sort the per-thread emits into a happens-before-consistent total order -- the emit
+ * (file) order is NOT such an order across threads.  No-op (one predictable branch)
+ * when the env is unset.  Self-contained leaf mutex for the append; the clock is a
+ * separate global SC counter ticked AT the transition point, NOT under the emit mutex
+ * (that would merely reproduce the broken emit order).  Only runloom edit to the
+ * CPython tree (snapshot at Python/pystate.c.runloom-orig). */
+static int
+runloom_stw_enabled(void)
+{
+    static int e = -1;
+    if (e < 0) {
+        const char *p = getenv("RUNLOOM_STW_TRACE");
+        e = (p != NULL && p[0] != '\0') ? 1 : 0;
+    }
+    return e;
+}
+
+static unsigned long long runloom_stw_seq;
+
+static unsigned long long
+runloom_stw_tick(void)
+{
+    if (!runloom_stw_enabled()) {
+        return 0;
+    }
+    return _Py_atomic_add_uint64(&runloom_stw_seq, 1) + 1;
+}
+
+static void
+runloom_stw_trace(const char *action, unsigned long long id,
+                  void *ptr, unsigned long long seq)
+{
+    static PyMutex mtx;
+    static FILE *fp;
+    static int inited;
+    if (!runloom_stw_enabled()) {
+        return;
+    }
+    PyMutex_Lock(&mtx);
+    if (!inited) {
+        inited = 1;
+        const char *path = getenv("RUNLOOM_STW_TRACE");
+        if (path != NULL && path[0] != '\0') {
+            fp = fopen(path, "a");
+        }
+    }
+    if (fp != NULL) {
+        fprintf(fp, "{\"a\":\"%s\",\"t\":%llu,\"p\":%llu,\"s\":%llu}\n",
+                action, id, (unsigned long long)(uintptr_t)ptr, seq);
+        fflush(fp);
+    }
+    PyMutex_Unlock(&mtx);
+}
