# Copy to scripts/release_hosts.env (gitignored) and fill in YOUR values.
# Used by scripts/collect_wheels.sh.
#
# RUNLOOM_REPO_URL  leave UNSET to be prompted each run, or pin a URL.
# RUNLOOM_REF       branch/tag/sha; default main (override inline:
#                     RUNLOOM_REF=v0.1.0 ./scripts/collect_wheels.sh)
# RUNLOOM_WIN_PYENV pyenv-win version that drives cibuildwheel on Windows (default 3.12.10).
# RELEASE_SSH_HOSTS space-separated "<ssh-target>|<base-dir>|<kind>" entries, one
#                   per non-Linux platform.  kind = posix (mac, default) or windows
#                   (cmd.exe shell + pyenv).  A fresh clone dir is created under
#                   <base-dir> per run and deleted on exit.  Each host needs git,
#                   a C toolchain, the CPython matrix, and cibuildwheel>=2.20.
RELEASE_SSH_HOSTS="you@your-mac|/Users/you/rl-build|posix you@your-win|C:/rl-build|windows"
