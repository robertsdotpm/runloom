# Copy to scripts/release_hosts.env (gitignored) and fill in YOUR values.
# Used by scripts/collect_wheels.sh.

# Git URL every build host clones (so wheels come from committed code, not a
# dirty tree).  Default if unset: https://github.com/robertsdotpm/runloom.git
# RUNLOOM_REPO_URL="git@github.com:robertsdotpm/runloom.git"

# Branch / tag / sha to build.  Default if unset: main  (use a tag for releases)
# RUNLOOM_REF="v0.0.1"

# Non-Linux build hosts: space-separated "<ssh-target>:<remote-build-dir>".
# The local machine builds the Linux wheels; each host below builds its own
# platform's.  Each host needs git, a C toolchain, the CPython matrix, and
# `pip install "runloom[dev]"` (build + cibuildwheel>=2.20).  Leave empty to
# build only this machine's wheels.
RELEASE_SSH_HOSTS="m1@your-mac:/Users/m1/rl-build administrator@your-win:C:/rl-build"
