#!/usr/bin/env bash
# pre-commit (ADVISORY, NON-BLOCKING): print the audit-lens worklist for the
# files being committed.  It NEVER blocks a commit -- it only surfaces which
# taxonomy lenses (tools/audit/run_lens.py) to re-run for the touched paths, so
# the lens audit gets diff-time runtime without ever gating.  The lens output is
# a human/agent worklist, not a pass/fail verdict, which is why it lives here
# rather than in check_all_fast.
#
# Enable once per clone:  git config core.hooksPath .githooks
# Disable:                git config --unset core.hooksPath
set -u
ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
files=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$files" ] && exit 0
PY="$(command -v python3 || command -v python)"
[ -z "$PY" ] && exit 0            # no interpreter -> stay silent, never block
# run_lens.py --changed already exits 0 in every case; `|| true` is belt-and-braces
# so a lens-tool error can never block a commit.
"$PY" "$ROOT/tools/audit/run_lens.py" --changed $files 2>/dev/null || true
exit 0
