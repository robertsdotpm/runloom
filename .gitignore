# soak-harness raw samples (docs/dev/RELIABILITY_PROGRAM.md R1): keep the
# committed REPORT.md ledger entries, drop the large reproducible CSV/heartbeat
# artifacts + gdb hang dumps.
docs/dev/soak/**/worker*.csv
docs/dev/soak/**/*.hb
docs/dev/soak/**/hang_*.txt
docs/dev/soak/inbox_artifacts/
# canary soak artifacts (docs/dev/RELIABILITY_PROGRAM.md R6): keep REPORT.txt,
# drop the reproducible CSV/logs/crash captures.
docs/dev/soak/canary_*/canary.csv
docs/dev/soak/canary_*/*.log
docs/dev/soak/canary_*/*crash*.txt
# nightly coverage artifacts: heat-map HTML + raw logs are per-night bulk;
# the ledger + dated run.log summaries are the committed record
docs/dev/soak/coverage/*/html/
docs/dev/soak/coverage/*/workloads.log
